Project elasticsearch {
  database_type: 'Elasticsearch'
  Note: 'Используется как поисковый движок. Индекс наполняет Search Indexer по событиям из Kafka (идемпотентный upsert по id). Репликация: primary-replica, RF 2. Шардирование: индекс делится на shards средствами Elasticsearch.'
}

Table post_search_documents {
  id bigint [pk]
  author_id bigint [not null]
  author_name varchar(64) [not null]
  place_id bigint [note: 'null для постов без именованного места (безымянная точка по координатам)']
  place_name varchar(64)
  place_country varchar(64)
  description text [not null]
  photos json
  search_text text [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table place_search_documents {
  id bigint [pk]
  name varchar(64) [not null]
  country varchar(64) [not null]
  description text [not null]
  posts_count bigint [not null]
  search_text text [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]
}
