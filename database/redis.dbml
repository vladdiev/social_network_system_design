Project redis {
  database_type: 'Redis'
  Note: 'Кэш горячего подмножества поверх PostgreSQL (cache-aside, allkeys-lru). Репликация: Sentinel master-slave, RF 2. Шардирование не используется.'
}

Enum feed_type {
  traveler
  subscriptions
}

Table post_read_models {
  post_id bigint [pk]
  author_id bigint [not null]
  author_name varchar(64) [not null]
  latitude numeric(9,6) [not null]
  longitude numeric(9,6) [not null]
  place_id bigint
  place_name varchar(64)
  place_country varchar(64)
  description varchar(2000) [not null]
  photos json
  like_count bigint [not null]
  dislike_count bigint [not null]
  comments_count bigint [not null]
  created_at timestamp [not null]
  updated_at timestamp [not null]

  Note: 'Снапшот горячего поста для лент. Счетчики like/dislike/comments денормализованы. На лайк счетчик инкрементится в Redis (write-behind: posts.like_count флашится в PostgreSQL фоново, eventual consistency), снапшот инвалидируется только при редактировании поста, не на каждый лайк. Истина факта лайка и счетчика в PostgreSQL, кэш восстановим.'
}

Table traveler_feed_read_models {
  cache_key varchar(128) [pk]
  traveler_id bigint [not null]
  type feed_type [not null]
  post_ids json [not null]
  next_cursor bigint
  updated_at timestamp [not null]

  Note: 'Предрассчитанная лента по подпискам или автору. Физически Redis Sorted Set: score = created_at, member = post_id (де-дупликация, пагинация по диапазону). cache_key: traveler_feed:{traveler_id}:{type}. Rebuild из PostgreSQL.'
}

Table place_posts_read_models {
  cache_key varchar(128) [pk]
  place_id bigint [not null]
  post_ids json [not null]
  next_cursor bigint
  updated_at timestamp [not null]

  Note: 'Предрассчитанный список постов места. Физически Redis Sorted Set: score = created_at, member = post_id. cache_key: place_posts:{place_id}. Rebuild из PostgreSQL.'
}
